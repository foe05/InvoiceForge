# ============================================================
# InvoiceForge – Umgebungsvariablen
# ============================================================
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an.
# cp .env.example .env

# --- Anwendung ---
# Umgebung: development | staging | production
APP_ENV=development
# Debug-Modus (ausführliche Fehlermeldungen, kein Caching)
APP_DEBUG=true
# Geheimer Schlüssel für Sessions/Tokens (in Produktion ändern!)
APP_SECRET_KEY=change-me-in-production

# --- Datenbank ---
# PostgreSQL (Produktion):
DATABASE_URL=postgresql+asyncpg://invoiceforge:invoiceforge@localhost:5432/invoiceforge
# SQLite (Entwicklung, alternativ):
# DATABASE_URL=sqlite+aiosqlite:///data/invoiceforge.db

# --- Redis (für ARQ Background-Jobs) ---
REDIS_URL=redis://localhost:6379/0

# --- KoSIT Validator (Schematron, optional) ---
# URL des KoSIT Validator Docker-Sidecar
KOSIT_VALIDATOR_URL=http://localhost:8080

# --- Dateispeicher ---
# Lokaler Basispfad für hochgeladene und generierte Dateien
STORAGE_BASE_PATH=./data/storage
# Maximale Upload-Größe in MB
UPLOAD_MAX_SIZE_MB=50

# --- Validierungsschemas (offline) ---
# Verzeichnis mit heruntergeladenen XSD/Schematron-Schemas
# Herunterladen: ./scripts/download_schemas.sh
SCHEMA_DIR=./data/schemas

# --- Nextcloud / WebDAV (optional) ---
# Aktivieren für Nextcloud-Integration
WEBDAV_ENABLED=false
# Nextcloud WebDAV-URL (bevorzugt):
NEXTCLOUD_URL=
# Nextcloud App-Passwort Zugangsdaten:
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
# Basis-Pfad auf Nextcloud für InvoiceForge-Dateien:
NEXTCLOUD_ROOT_PATH=/InvoiceForge
# Alternative WebDAV-Variablen (Fallback):
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# --- LLM-Extraktion (optional) ---
# LLM-Anbieter: none | anthropic | ollama
LLM_PROVIDER=none
# Anthropic API-Key (wenn LLM_PROVIDER=anthropic):
ANTHROPIC_API_KEY=
# Ollama Server-URL (wenn LLM_PROVIDER=ollama):
OLLAMA_BASE_URL=http://localhost:11434

# --- OCR (optional) ---
# Pfad zum Tesseract-OCR-Binary
TESSERACT_CMD=tesseract

# --- Standard-Einstellungen ---
# Standard-Ausgabeformat: zugferd_pdf | xrechnung_cii | xrechnung_ubl
DEFAULT_OUTPUT_FORMAT=zugferd_pdf
# Standard-ZUGFeRD-Profil: MINIMUM | BASIC WL | BASIC | EN 16931 | EXTENDED | XRECHNUNG
DEFAULT_ZUGFERD_PROFILE=EN 16931
