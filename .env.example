# InvoiceForge Environment Configuration

# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://invoiceforge:invoiceforge@localhost:5432/invoiceforge

# Redis (for ARQ background jobs)
REDIS_URL=redis://localhost:6379/0

# KoSIT Validator
KOSIT_VALIDATOR_URL=http://localhost:8080

# File storage
STORAGE_BASE_PATH=./data/storage
UPLOAD_MAX_SIZE_MB=50

# WebDAV (optional)
WEBDAV_ENABLED=false
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# LLM extraction (optional)
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OCR (optional)
TESSERACT_CMD=tesseract
